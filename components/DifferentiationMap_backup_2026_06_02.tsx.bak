import { differentiationTopics } from "../data/differentiation";

function getTitle(id: string) {
  return (
    differentiationTopics.find(t => t.id === id)?.title || id
  );
}

function getTopicsAtLevel(level: number) {
  return differentiationTopics.filter(
    topic => topic.level === level
  );
}

export default function DifferentiationMap() {

  return (
    <div className="bg-white rounded-2xl shadow-lg p-6">
      <h2 className="text-2xl font-bold mb-6 text-center">
        Differentiation Dependency Map
      </h2>

      <div className="space-y-4">

        <div className="flex justify-center gap-4">
          {getTopicsAtLevel(1).map(topic => (
            <TopicBox
              key={topic.id}
              title={topic.title}
              dependsOn={topic.dependsOn}
            />
          ))}
        </div>
        <div className="text-center text-2xl">↓</div>

        <div className="flex justify-center">
          {getTopicsAtLevel(2).map(topic => (
            <TopicBox
              key={topic.id}
              title={topic.title}
              dependsOn={topic.dependsOn}
            />
          ))}
        </div>



        <div className="text-center text-2xl">↓</div>

        <div className="flex justify-center">
          {getTopicsAtLevel(3).map(topic => (
            <TopicBox
              key={topic.id}
              title={topic.title}
              dependsOn={topic.dependsOn}
            />
          ))}
        </div>

        <div className="text-center text-2xl">↓</div>

        <div className="flex justify-center">
          {getTopicsAtLevel(4).map(topic => (
            <TopicBox
              key={topic.id}
              title={topic.title}
              dependsOn={topic.dependsOn}
            />
          ))}
        </div>

      </div>
    </div>
  );
}

function TopicBox({
  title,
  dependsOn = [],
}: {
  title: string;
  dependsOn?: string[];
}) {
  return (
    <div className="bg-blue-100 border border-blue-300 rounded-xl px-4 py-3 font-semibold">
      <div>{title}</div>

      {dependsOn.length > 0 && (
        <div className="text-xs text-gray-600 mt-2">
          Depends on: {dependsOn.map(getTitle).join(", ")}
        </div>
      )}
    </div>
  );
}